    <div class="modal" id="adminLoginModal">
        <div class="modal-content">
            <button class="close-modal" id="closeAdminModal">&times;</button>
            <h2 style="color: var(--primary-blue); text-align: center; margin-bottom: 2rem;">Вход в админ-панель</h2>
            <form id="adminLoginForm">
                <div class="form-group">
                    <label for="adminLogin">Логин</label>
                    <input type="text" id="adminLogin" required placeholder="Введите логин">
                </div>
