    <script type="module">
        import { initializeApp } from 'https://www.gstatic.com/firebasejs/9.6.10/firebase-app.js';
        import { getDatabase, ref, onValue } from 'https://www.gstatic.com/firebasejs/9.6.10/firebase-database.js';

        const firebaseConfig = {
            apiKey: "AIzaSyDcyOWAF7TA8h8P36Sk5EbDPzA9sEFuTXo",
            authDomain: "ggpoint-shop.firebaseapp.com",
            databaseURL: "https://ggpoint-shop-default-rtdb.firebaseio.com",
            projectId: "ggpoint-shop",
            storageBucket: "ggpoint-shop.firebasestorage.app",
            messagingSenderId: "182227173652",
            appId: "1:182227173652:web:0949e2edae9900afd98201"
        };

        const app = initializeApp(firebaseConfig);
        const database = getDatabase(app);

        // Получаем ID товара из URL
        const urlParams = new URLSearchParams(window.location.search);
        const productId = urlParams.get('id');

        if (!productId) {
            window.location.href = 'catalog.html';
        }

        let product = null;
        let products = [];
        let hotPrices = {};
        let brands = {};
        let currentImageIndex = 0;
        let images = [];
        let isFullscreenZoomed = false;
        let soonBanner = null;
        let currentSoonSlide = 0;
        let soonInterval;

        // Загрузка данных
        function loadData() {
            const productRef = ref(database, 'products/' + productId);
            onValue(productRef, (snapshot) => {
                product = snapshot.val();
                if (!product) {
                    window.location.href = 'catalog.html';
                    return;
                }
                
                document.title = `${product.name} - GGPoint`;
                renderProduct();
            });

            const productsRef = ref(database, 'products');
            onValue(productsRef, (snapshot) => {
                const data = snapshot.val();
                products = data ? Object.values(data) : [];
                renderRelatedProducts();
            });

            const hotPricesRef = ref(database, 'hotPrices');
            onValue(hotPricesRef, (snapshot) => {
                hotPrices = snapshot.val() || {};
                renderProduct();
            });

            const brandsRef = ref(database, 'brands');
            onValue(brandsRef, (snapshot) => {
                brands = snapshot.val() || {};
                renderProduct();
            });

            // Загрузка баннера СКОРО
            const soonRef = ref(database, 'soonBlock');
            onValue(soonRef, (snapshot) => {
                const data = snapshot.val();
                if (data && data.active) {
                    document.getElementById('soonBlock').style.display = 'block';
                    document.getElementById('soonBlockTitle').textContent = data.title || 'Скоро в продаже!';
                    document.getElementById('soonBlockDescription').textContent = data.description || 'Мы готовим для вас кое-что особенное. Следите за обновлениями!';
                    
                    const imgElement = document.getElementById('soonBlockImg');
                    if (data.image) {
                        imgElement.src = data.image;
                        imgElement.style.display = 'block';
                        document.querySelector('.soon-block-image').style.display = 'block';
                    } else {
                        document.querySelector('.soon-block-image').style.display = 'none';
                    }
                }
            });

            // Загрузка баннера для модалки
            const bannerRef = ref(database, 'banners/soon');
            onValue(bannerRef, (snapshot) => {
                soonBanner = snapshot.val();
            });
        }

        // Функция для извлечения YouTube ID
        function getYouTubeId(url) {
            if (!url) return null;
            
            // Если это уже ID (11 символов)
            if (/^[a-zA-Z0-9_-]{11}$/.test(url)) {
                return url;
            }
            
            // Разные форматы YouTube ссылок
            const patterns = [
                /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&?/]+)/i,
                /youtube\.com\/watch\?.*v=([^&]+)/i,
                /youtu\.be\/([^?]+)/i,
                /youtube\.com\/shorts\/([^?]+)/i
            ];
            
            for (let pattern of patterns) {
                const match = url.match(pattern);
                if (match) return match[1];
            }
            
            return null;
        }

        // Рендер YouTube видео внизу - ИСПРАВЛЕНО
        function renderYouTubeVideoBottom() {
            const videoContainer = document.getElementById('videoContainerBottom');
            
            if (!product.video) {
                videoContainer.innerHTML = `
                    <div class="no-video-bottom">
                        <i class="fab fa-youtube"></i>
                        <h4>Видеообзор скоро появится</h4>
                        <p>Мы готовим подробный обзор этого товара</p>
                    </div>
                `;
                return;
            }
            
            const videoId = getYouTubeId(product.video);
            
            if (videoId) {
                videoContainer.innerHTML = `
                    <iframe 
                        src="https://www.youtube.com/embed/${videoId}?autoplay=0&rel=0&modestbranding=1" 
                        title="YouTube video player" 
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen
                        loading="lazy">
                    </iframe>
                `;
            } else {
                videoContainer.innerHTML = `
                    <div class="no-video-bottom">
                        <i class="fab fa-youtube"></i>
                        <h4>Видео временно недоступно</h4>
                        <p>ID видео: ${product.video}</p>
                    </div>
                `;
            }
        }

        // Рендер страницы
        function renderProduct() {
            if (!product) return;
            
            images = product.images || ['https://via.placeholder.com/500x400/ffffff/333333?text=Нет+фото'];
            
            // Заголовок
            document.getElementById('productTitle').textContent = product.name;
            document.getElementById('productCategory').textContent = getCategoryName(product.category);
            
            // Бренд
            const brandInfo = Object.values(brands).find(b => b.name === product.brand);
            if (brandInfo) {
                document.getElementById('productBrand').innerHTML = `
                    <img src="${brandInfo.icon}" alt="${product.brand}" loading="lazy" onerror="this.style.display='none'">
                    <span>${product.brand}</span>
                `;
            }
            
            // Цена
            document.getElementById('productPrice').textContent = product.price;
            
            // Скидка
            if (hotPrices[productId]) {
                document.getElementById('saleBadge').innerHTML = `
                    <span class="product-badge sale">
                        <i class="fas fa-fire"></i> Скидка!
                    </span>
                `;
                
                const oldPrice = parsePrice(product.price);
                const newPrice = Math.round(oldPrice * 0.7);
                document.getElementById('oldPrice').style.display = 'inline';
                document.getElementById('oldPrice').textContent = formatPrice(oldPrice);
                document.getElementById('discountInfo').style.display = 'inline';
                document.getElementById('discountInfo').textContent = '🔥 -30%';
            }
            
            // Описание
            document.getElementById('productDescription').textContent = product.description.substring(0, 200) + '...';
            document.getElementById('fullDescription').textContent = product.description;
            
            // Характеристики
            if (product.features && product.features.length > 0) {
                document.getElementById('featuresList').innerHTML = product.features.map(f => 
                    `<li>${f}</li>`
                ).join('');
                
                const specsTable = document.getElementById('specsTable');
                specsTable.innerHTML = `
                    <tr><td>Бренд</td><td>${product.brand || '-'}</td></tr>
                    <tr><td>Категория</td><td>${getCategoryName(product.category)}</td></tr>
                    <tr><td>Артикул</td><td>${productId}</td></tr>
                    ${product.features.map(f => {
                        const parts = f.split(':');
                        if (parts.length > 1) {
                            return `<tr><td>${parts[0].trim()}</td><td>${parts.slice(1).join(':').trim()}</td></tr>`;
                        }
                        return `<tr><td>Характеристика</td><td>${f}</td></tr>`;
                    }).join('')}
                `;
            }
            
            // YouTube видео
            renderYouTubeVideoBottom();
            
            // Галерея
            renderGallery();
        }

        // Галерея
        function renderGallery() {
            document.getElementById('photoCount').textContent = `${images.length} фото`;
            
            // Главное изображение
            document.getElementById('mainImage').src = images[0];
            
            // Миниатюры
            const thumbnailGrid = document.getElementById('thumbnailGrid');
            thumbnailGrid.innerHTML = images.map((img, index) => `
                <img src="${img}" class="thumbnail ${index === 0 ? 'active' : ''}" onclick="setImage(${index})">
            `).join('');
            
            document.getElementById('prevImageBtn').disabled = images.length <= 1;
            document.getElementById('nextImageBtn').disabled = images.length <= 1;
        }

        // Похожие товары
        function renderRelatedProducts() {
            if (!product) return;
            
            const related = products
                .filter(p => p.category === product.category && p.id != productId)
                .slice(0, 4);
            
            const grid = document.getElementById('relatedProducts');
            grid.innerHTML = '';
            
            if (related.length === 0) {
                grid.innerHTML = '<p style="color: var(--text-gray);">Похожих товаров не найдено</p>';
                return;
            }
            
            related.forEach(p => {
                grid.appendChild(createProductCard(p));
            });
        }

        // Создание карточки товара
        function createProductCard(product) {
            const card = document.createElement('div');
            card.className = 'product-card';
            
            const isHot = hotPrices[product.id];
            const imageUrl = product.images?.[0] || 'https://via.placeholder.com/300x200/ffffff/333333?text=Нет+фото';
            
            card.innerHTML = `
                ${isHot ? '<div class="product-badge-sale"><i class="fas fa-fire"></i> Скидка</div>' : ''}
                <div class="product-image-container">
                    <img src="${imageUrl}" class="product-image" alt="${product.name}">
                </div>
                <div class="product-info">
                    <div class="product-category">${getCategoryName(product.category)}</div>
                    <h3 class="product-name">${product.name}</h3>
                    <p class="product-price">${product.price}</p>
                </div>
            `;
            
            card.addEventListener('click', () => {
                window.location.href = `product.html?id=${product.id}`;
            });
            
            return card;
        }

        // Вспомогательные функции
        function getCategoryName(key) {
            const categories = {
                'мышь': 'Игровая мышь',
                'клавиатура': 'Клавиатура',
                'наушники': 'Наушники',
                'монитор': 'Монитор',
                'keycaps': 'Кейкапы'
            };
            return categories[key] || key;
        }

        function parsePrice(priceStr) {
            if (!priceStr) return 0;
            return parseInt(priceStr.replace(/[^\d]/g, '')) || 0;
        }

        function formatPrice(price) {
            return price.toLocaleString() + ' UZS';
        }

        // Навигация
        window.goBack = () => {
            if (document.referrer) {
                window.history.back();
            } else {
                window.location.href = 'catalog.html';
            }
        };

        window.closeAndGoBack = () => {
            if (document.referrer) {
                window.history.back();
            } else {
                window.location.href = 'catalog.html';
            }
        };

        // Обработка клавиши ESC
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                if (document.getElementById('fullscreenGallery').classList.contains('active')) {
                    closeFullscreen();
                } else if (document.getElementById('soonModal').classList.contains('active')) {
                    closeSoonModal();
                } else {
                    goBack();
                }
            }
        });

        // Корзина
        let cart = JSON.parse(localStorage.getItem('cart')) || [];
        
        function updateCartCount() {
            const count = cart.reduce((sum, item) => sum + (item.quantity || 1), 0);
            document.querySelectorAll('.cart-count').forEach(el => {
                el.textContent = count;
            });
        }

        function showNotification(message) {
            const notification = document.createElement('div');
            notification.className = 'notification';
            notification.textContent = message;
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        // Глобальные функции для галереи
        window.setImage = (index) => {
            currentImageIndex = index;
            document.getElementById('mainImage').src = images[index];
            document.getElementById('fullscreenImage').src = images[index];
            
            document.querySelectorAll('.thumbnail').forEach((thumb, i) => {
                thumb.classList.toggle('active', i === index);
            });
        };

        window.changeImage = (delta) => {
            const newIndex = currentImageIndex + delta;
            if (newIndex >= 0 && newIndex < images.length) {
                setImage(newIndex);
            }
        };

        // Зум на главном фото
        document.getElementById('mainImageContainer').addEventListener('click', function(e) {
            const img = document.getElementById('mainImage');
            img.classList.toggle('zoomed');
        });

        // Полноэкранная галерея
        window.openFullscreen = () => {
            const gallery = document.getElementById('fullscreenGallery');
            document.getElementById('fullscreenImage').src = images[currentImageIndex];
            document.getElementById('fullscreenCounter').textContent = 
                `${currentImageIndex + 1} / ${images.length}`;
            gallery.classList.add('active');
            document.body.style.overflow = 'hidden';
            isFullscreenZoomed = false;
        };

        window.closeFullscreen = () => {
            document.getElementById('fullscreenGallery').classList.remove('active');
            document.body.style.overflow = '';
        };

        window.fullscreenChangeImage = (delta) => {
            let newIndex = currentImageIndex + delta;
            if (newIndex < 0) newIndex = images.length - 1;
            if (newIndex >= images.length) newIndex = 0;
            
            currentImageIndex = newIndex;
            document.getElementById('fullscreenImage').src = images[currentImageIndex];
            document.getElementById('fullscreenCounter').textContent = 
                `${currentImageIndex + 1} / ${images.length}`;
            document.getElementById('fullscreenImage').classList.remove('zoomed');
            setImage(currentImageIndex);
            isFullscreenZoomed = false;
        };

        window.toggleFullscreenZoom = () => {
            const img = document.getElementById('fullscreenImage');
            img.classList.toggle('zoomed');
            isFullscreenZoomed = !isFullscreenZoomed;
        };

        // Действия с товаром
        window.showComingSoon = () => {
            showNotification('🔔 Функция покупки скоро появится!');
        };

        window.addToFavorites = () => {
            let favorites = JSON.parse(localStorage.getItem('favorites')) || [];
            if (!favorites.includes(productId)) {
                favorites.push(productId);
                localStorage.setItem('favorites', JSON.stringify(favorites));
                showNotification('❤️ Товар добавлен в избранное');
            } else {
                showNotification('Товар уже в избранном');
            }
        };

        // Функции для модального окна СКОРО
        window.openSoonModal = () => {
            if (!soonBanner || !soonBanner.images || soonBanner.images.length === 0) {
                showTestSoonModal();
                return;
            }
            
            const modal = document.getElementById('soonModal');
            const gallery = document.getElementById('soonGallery');
            const nav = document.getElementById('soonNav');
            const counter = document.getElementById('soonCounter');
            
            gallery.innerHTML = soonBanner.images.map((img, index) => `
                <div class="soon-slide ${index === 0 ? 'active' : ''}" style="background-image: url('${img}')">
                    <div class="soon-overlay"></div>
                    <div class="soon-text-content">
                        <h2>${soonBanner.title || 'СКОРО!'}</h2>
                        <h3>${soonBanner.subtitle || ''}</h3>
                        <p>${soonBanner.description || ''}</p>
                        <a href="${soonBanner.buttonLink || '#'}" class="soon-button" target="_blank">
                            ${soonBanner.buttonText || 'Узнать подробнее'}
                        </a>
                    </div>
                </div>
            `).join('');
            
            nav.innerHTML = soonBanner.images.map((_, index) => `
                <div class="soon-dot ${index === 0 ? 'active' : ''}" onclick="goToSoonSlide(${index})"></div>
            `).join('');
            
            counter.textContent = `1 / ${soonBanner.images.length}`;
            currentSoonSlide = 0;
            
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
            
            startSoonAutoPlay();
        };

        function showTestSoonModal() {
            const modal = document.getElementById('soonModal');
            const gallery = document.getElementById('soonGallery');
            const nav = document.getElementById('soonNav');
            const counter = document.getElementById('soonCounter');
            
            const testImages = [
                'https://images.unsplash.com/photo-1587202372775-e229f172b9d7?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80',
                'https://images.unsplash.com/photo-1595225476474-87563907c212?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80',
                'https://images.unsplash.com/photo-1603048588665-791ca8aea617?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80'
            ];
            
            gallery.innerHTML = testImages.map((img, index) => `
                <div class="soon-slide ${index === 0 ? 'active' : ''}" style="background-image: url('${img}')">
                    <div class="soon-overlay"></div>
                    <div class="soon-text-content">
                        <h2>СКОРО!</h2>
                        <h3>Мы готовим для вас кое-что особенное</h3>
                        <p>Следите за обновлениями в нашем Telegram канале</p>
                        <a href="https://t.me/GGPointUz" class="soon-button" target="_blank">
                            Подписаться
                        </a>
                    </div>
                </div>
            `).join('');
            
            nav.innerHTML = testImages.map((_, index) => `
                <div class="soon-dot ${index === 0 ? 'active' : ''}" onclick="goToSoonSlide(${index})"></div>
            `).join('');
            
            counter.textContent = `1 / ${testImages.length}`;
            currentSoonSlide = 0;
            
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
            startSoonAutoPlay();
        }

        window.closeSoonModal = () => {
            document.getElementById('soonModal').classList.remove('active');
            document.body.style.overflow = '';
            stopSoonAutoPlay();
        };

        window.changeSoonSlide = (direction) => {
            const slides = document.querySelectorAll('.soon-slide');
            const dots = document.querySelectorAll('.soon-dot');
            const counter = document.getElementById('soonCounter');
            
            if (!slides.length) return;
            
            slides[currentSoonSlide].classList.remove('active');
            dots[currentSoonSlide].classList.remove('active');
            
            currentSoonSlide = (currentSoonSlide + direction + slides.length) % slides.length;
            
            slides[currentSoonSlide].classList.add('active');
            dots[currentSoonSlide].classList.add('active');
            counter.textContent = `${currentSoonSlide + 1} / ${slides.length}`;
        };

        window.goToSoonSlide = (index) => {
            const slides = document.querySelectorAll('.soon-slide');
            const dots = document.querySelectorAll('.soon-dot');
            const counter = document.getElementById('soonCounter');
            
            if (!slides.length) return;
            
            slides[currentSoonSlide].classList.remove('active');
            dots[currentSoonSlide].classList.remove('active');
            
            currentSoonSlide = index;
            
            slides[currentSoonSlide].classList.add('active');
            dots[currentSoonSlide].classList.add('active');
            counter.textContent = `${currentSoonSlide + 1} / ${slides.length}`;
        };

        function startSoonAutoPlay() {
            stopSoonAutoPlay();
            soonInterval = setInterval(() => changeSoonSlide(1), 5000);
        }

        function stopSoonAutoPlay() {
            if (soonInterval) clearInterval(soonInterval);
        }

        // Навигация клавишами для галереи
        document.addEventListener('keydown', (e) => {
            if (document.getElementById('fullscreenGallery').classList.contains('active')) {
                if (e.key === 'ArrowLeft') fullscreenChangeImage(-1);
                if (e.key === 'ArrowRight') fullscreenChangeImage(1);
                if (e.key === 'Escape') closeFullscreen();
                if (e.key === ' ') {
                    e.preventDefault();
                    toggleFullscreenZoom();
                }
            }
        });

        // Вкладки
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                
                btn.classList.add('active');
                document.getElementById(`tab-${btn.dataset.tab}`).classList.add('active');
            });
        });

        // Back to top
        const backToTop = document.getElementById('backToTop');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                backToTop.classList.add('show');
            } else {
                backToTop.classList.remove('show');
            }
        });

        backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // Админка
        document.getElementById('adminBtn').addEventListener('click', () => {
            window.location.href = 'admin-panel.html';
        });

        // Инициализация
        loadData();
        updateCartCount();
    </script>
</body>
</html>
