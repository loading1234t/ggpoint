<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- SEO -->
    <title>Товар - GGPoint</title>
    <meta name="description" content="Подробное описание товара">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="images/favicon-32x32.png">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- CSS -->
    <link rel="stylesheet" href="css/style.css">
    
    <style>
        /* Стили для страницы товара */
        .product-page {
            padding: 6rem 2rem 4rem;
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
        }
        
        /* Кнопка назад */
        .back-button {
            position: absolute;
            top: 6rem;
            left: 2rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 1.2rem;
            background: var(--card-bg);
            border: 2px solid var(--primary-blue);
            color: var(--primary-blue);
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 10;
        }
        
        .back-button:hover {
            background: var(--primary-blue);
            color: white;
            transform: translateX(-5px);
        }
        
        .back-button i {
            font-size: 0.9rem;
        }
        
        /* Маленькая кнопка закрытия */
        .close-button {
            position: absolute;
            top: 6rem;
            right: 2rem;
            width: 40px;
            height: 40px;
            background: var(--card-bg);
            border: 2px solid var(--sale-red);
            color: var(--sale-red);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 10;
            font-size: 1.2rem;
        }
        
        .close-button:hover {
            background: var(--sale-red);
            color: white;
            transform: scale(1.1);
        }
        
        .product-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            margin-top: 2rem;
        }
        
        /* Галерея для осмотра фото */
        .product-gallery {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 1.5rem;
            border: 2px solid #334155;
        }
        
        .main-image-container {
            position: relative;
            width: 100%;
            height: 500px;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 1rem;
            cursor: zoom-in;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .main-image {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            transition: transform 0.3s ease;
        }
        
        .main-image.zoomed {
            transform: scale(2);
            cursor: zoom-out;
        }
        
        .zoom-hint {
            position: absolute;
            bottom: 10px;
            right: 10px;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            pointer-events: none;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        
        .zoom-hint i {
            font-size: 0.9rem;
        }
        
        .gallery-nav {
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            transform: translateY(-50%);
            display: flex;
            justify-content: space-between;
            padding: 0 1rem;
            pointer-events: none;
        }
        
        .gallery-btn {
            width: 40px;
            height: 40px;
            background: rgba(0, 0, 0, 0.7);
            border: 2px solid white;
            border-radius: 50%;
            color: white;
            cursor: pointer;
            pointer-events: all;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .gallery-btn:hover:not(:disabled) {
            background: var(--primary-blue);
            transform: scale(1.1);
        }
        
        .gallery-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }
        
        .thumbnail-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 0.5rem;
            margin-top: 1rem;
        }
        
        .thumbnail {
            width: 100%;
            height: 80px;
            object-fit: contain;
            background: white;
            border-radius: 8px;
            cursor: pointer;
            border: 2px solid transparent;
            transition: all 0.3s ease;
            padding: 0.2rem;
        }
        
        .thumbnail:hover {
            transform: translateY(-2px);
            border-color: var(--primary-blue);
        }
        
        .thumbnail.active {
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.3);
        }
        
        .photo-count {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 1rem;
            padding: 0.5rem 1rem;
            background: rgba(37, 99, 235, 0.1);
            border-radius: 8px;
            color: var(--text-gray);
        }
        
        .fullscreen-btn {
            background: transparent;
            border: 1px solid var(--primary-blue);
            color: var(--primary-blue);
            padding: 0.3rem 1rem;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        
        .fullscreen-btn:hover {
            background: var(--primary-blue);
            color: white;
        }
        
        /* Информация о товаре */
        .product-info {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 2rem;
            border: 2px solid #334155;
        }
        
        .product-badge {
            display: inline-block;
            padding: 0.3rem 1rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }
        
        .product-badge.sale {
            background: var(--hot-gradient);
            color: white;
        }
        
        .product-badge.new {
            background: var(--success-green);
            color: white;
        }
        
        .product-title {
            font-size: 2rem;
            margin-bottom: 1rem;
            color: var(--text-light);
            line-height: 1.3;
        }
        
        .product-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }
        
        .product-category {
            color: var(--primary-blue);
            background: rgba(37, 99, 235, 0.1);
            padding: 0.3rem 1rem;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
        }
        
        .product-brand {
            color: var(--text-gray);
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        
        .product-brand img {
            height: 25px;
            filter: brightness(0) invert(1);
        }
        
        .product-price-block {
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(124, 58, 237, 0.1) 100%);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 2px solid var(--primary-blue);
        }
        
        .current-price {
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--primary-blue);
        }
        
        .old-price {
            font-size: 1.3rem;
            color: var(--text-gray);
            text-decoration: line-through;
            margin-left: 1rem;
        }
        
        .discount-info {
            display: inline-block;
            background: var(--hot-gradient);
            color: white;
            padding: 0.2rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            margin-left: 1rem;
        }
        
        .product-description {
            margin-bottom: 2rem;
            color: var(--text-gray);
            line-height: 1.7;
        }
        
        .product-features {
            margin-bottom: 2rem;
        }
        
        .product-features h3 {
            color: var(--text-light);
            margin-bottom: 1rem;
            font-size: 1.2rem;
        }
        
        .features-list {
            list-style: none;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.8rem;
        }
        
        .features-list li {
            color: var(--text-gray);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.95rem;
        }
        
        .features-list li::before {
            content: '✓';
            color: var(--success-green);
            font-weight: bold;
        }
        
        /* Кнопки */
        .product-actions {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        
        .action-btn {
            flex: 1;
            padding: 1rem;
            border: 2px solid;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        
        .action-btn.primary {
            background: var(--gradient);
            border-color: transparent;
            color: white;
        }
        
        .action-btn.primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }
        
        .action-btn.secondary {
            background: transparent;
            border-color: var(--primary-blue);
            color: var(--primary-blue);
        }
        
        .action-btn.secondary:hover {
            background: var(--primary-blue);
            color: white;
        }
        
        .delivery-info {
            background: rgba(13, 148, 136, 0.1);
            border: 2px solid var(--accent-teal);
            border-radius: 12px;
            padding: 1rem;
        }
        
        .delivery-item {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            color: var(--text-gray);
            margin: 0.5rem 0;
            font-size: 0.95rem;
        }
        
        .delivery-item i {
            color: var(--accent-teal);
            width: 20px;
        }
        
        /* YouTube плеер внизу */
        .youtube-section-bottom {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 2rem;
            border: 2px solid var(--primary-blue);
            margin: 2rem 0;
            position: relative;
            overflow: hidden;
        }
        
        .youtube-section-bottom::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 150px;
            height: 150px;
            background: linear-gradient(135deg, transparent 50%, rgba(255,0,0,0.1) 50%);
            border-radius: 0 20px 0 0;
        }
        
        .youtube-header-bottom {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            position: relative;
        }
        
        .youtube-icon-large {
            width: 60px;
            height: 60px;
            background: #ff0000;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            box-shadow: 0 10px 20px rgba(255,0,0,0.3);
        }
        
        .youtube-title {
            flex: 1;
        }
        
        .youtube-title h3 {
            color: var(--text-light);
            font-size: 1.8rem;
            margin-bottom: 0.3rem;
        }
        
        .youtube-title p {
            color: var(--text-gray);
            font-size: 1rem;
        }
        
        .youtube-badge {
            background: rgba(255,0,0,0.1);
            color: #ff0000;
            padding: 0.5rem 1.5rem;
            border-radius: 30px;
            font-weight: 600;
            border: 2px solid #ff0000;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .video-container-bottom {
            position: relative;
            width: 100%;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 15px 30px rgba(0,0,0,0.3);
            border: 2px solid #ff0000;
            margin-top: 1rem;
            background: #000;
            min-height: 200px;
        }
        
        .video-container-bottom iframe {
            width: 100%;
            height: 450px;
            border: none;
            display: block;
        }
        
        .no-video-bottom {
            text-align: center;
            padding: 4rem;
            background: linear-gradient(135deg, rgba(255,0,0,0.05) 0%, rgba(0,0,0,0.2) 100%);
            border-radius: 16px;
            color: var(--text-gray);
            border: 2px dashed #ff0000;
        }
        
        .no-video-bottom i {
            font-size: 5rem;
            color: #ff0000;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
        
        .no-video-bottom h4 {
            color: var(--text-light);
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        
        /* Вкладки */
        .product-tabs {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 2rem;
            border: 2px solid #334155;
            margin: 2rem 0;
        }
        
        .tabs-header {
            display: flex;
            gap: 1rem;
            border-bottom: 2px solid #334155;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }
        
        .tab-btn {
            padding: 1rem 2rem;
            background: transparent;
            border: none;
            color: var(--text-gray);
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }
        
        .tab-btn::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--primary-blue);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        
        .tab-btn:hover {
            color: var(--primary-blue);
        }
        
        .tab-btn.active {
            color: var(--primary-blue);
        }
        
        .tab-btn.active::after {
            transform: scaleX(1);
        }
        
        .tab-content {
            display: none;
        }
        
        .tab-content.active {
            display: block;
        }
        
        .specs-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .specs-table tr {
            border-bottom: 1px solid #334155;
        }
        
        .specs-table td {
            padding: 1rem;
            color: var(--text-gray);
        }
        
        .specs-table td:first-child {
            font-weight: 600;
            color: var(--text-light);
            width: 200px;
        }
        
        /* Полноэкранная галерея */
        .fullscreen-gallery {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.98);
            z-index: 3000;
            display: none;
            align-items: center;
            justify-content: center;
        }
        
        .fullscreen-gallery.active {
            display: flex;
        }
        
        .fullscreen-image-container {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        
        .fullscreen-image {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
            transition: transform 0.3s ease;
            cursor: zoom-in;
        }
        
        .fullscreen-image.zoomed {
            transform: scale(2);
            cursor: zoom-out;
        }
        
        .fullscreen-close {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.1);
            border: 2px solid white;
            border-radius: 50%;
            color: white;
            font-size: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 3001;
        }
        
        .fullscreen-close:hover {
            background: var(--sale-red);
            transform: scale(1.1);
        }
        
        .fullscreen-nav {
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            transform: translateY(-50%);
            display: flex;
            justify-content: space-between;
            padding: 0 2rem;
            pointer-events: none;
            z-index: 3001;
        }
        
        .fullscreen-nav-btn {
            width: 60px;
            height: 60px;
            background: rgba(255,255,255,0.1);
            border: 2px solid white;
            border-radius: 50%;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            pointer-events: all;
            transition: all 0.3s ease;
        }
        
        .fullscreen-nav-btn:hover {
            background: var(--primary-blue);
            transform: scale(1.1);
        }
        
        .fullscreen-counter {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            color: white;
            background: rgba(0,0,0,0.5);
            padding: 0.5rem 1.5rem;
            border-radius: 30px;
            font-size: 1rem;
            border: 1px solid rgba(255,255,255,0.2);
            z-index: 3001;
        }
        
        /* Похожие товары */
        .related-products {
            margin-top: 4rem;
        }
        
        .related-title {
            font-size: 2rem;
            margin-bottom: 2rem;
            color: var(--text-light);
        }
        
        /* Уведомление */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--success-green);
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            z-index: 9999;
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        /* Модальное окно СКОРО */
        .soon-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
        }
        
        .soon-modal.active {
            display: flex;
        }
        
        .soon-modal-content {
            width: 90%;
            max-width: 1200px;
            background: var(--card-bg);
            border-radius: 20px;
            overflow: hidden;
            position: relative;
            border: 2px solid var(--primary-blue);
        }
        
        .soon-close {
            position: absolute;
            top: 15px;
            right: 15px;
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.2);
            border: 2px solid white;
            border-radius: 50%;
            color: white;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10001;
            transition: all 0.3s ease;
        }
        
        .soon-close:hover {
            background: var(--sale-red);
            transform: scale(1.1);
        }
        
        .soon-gallery {
            position: relative;
            width: 100%;
            height: 500px;
            overflow: hidden;
        }
        
        .soon-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        
        .soon-slide.active {
            opacity: 1;
        }
        
        .soon-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.7), rgba(124, 58, 237, 0.7));
        }
        
        .soon-text-content {
            position: relative;
            z-index: 1;
            padding: 3rem;
            color: white;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
        }
        
        .soon-text-content h2 {
            font-size: 3rem;
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .soon-text-content h3 {
            font-size: 2rem;
            margin-bottom: 1rem;
        }
        
        .soon-text-content p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            max-width: 600px;
        }
        
        .soon-button {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: white;
            color: var(--primary-blue);
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .soon-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 255, 255, 0.2);
        }
        
        .soon-nav {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 1rem;
            z-index: 10001;
        }
        
        .soon-dot {
            width: 12px;
            height: 12px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 50%;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .soon-dot.active {
            background: white;
            transform: scale(1.2);
        }
        
        .soon-counter {
            position: absolute;
            top: 15px;
            left: 15px;
            color: white;
            background: rgba(0, 0, 0, 0.5);
            padding: 0.3rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            z-index: 10001;
        }
        
        /* Кнопка СКОРО в хедере */
        .soon-btn {
            background: linear-gradient(135deg, #ff6b6b, #ff4757);
            border: none;
            color: white;
            padding: 0.8rem 1.2rem;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            position: relative;
            overflow: hidden;
            animation: pulse 2s infinite;
        }
        
        .soon-btn i {
            font-size: 1.1rem;
        }
        
        .soon-text {
            position: relative;
            z-index: 1;
        }
        
        .soon-pulse {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.3), transparent);
            animation: pulse-light 1.5s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.05);
            }
        }
        
        @keyframes pulse-light {
            0% {
                transform: translateX(-100%);
            }
            50%, 100% {
                transform: translateX(100%);
            }
        }
        
        @media (max-width: 768px) {
